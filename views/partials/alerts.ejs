<!-- Configuración global de SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  const Toast = Swal.mixin({
    toast: true,
    position: 'top-end',
    showConfirmButton: false,
    timer: 4000,
    timerProgressBar: true,
    background: '#f0f0f0',
    color: '#333',
    customClass: {
      popup: 'colored-toast'
    }
  });
</script>

<% if (mensaje) { %>
<script>
  Toast.fire({
    icon: '<%= mensaje.tipo %>',
    title: '<%= mensaje.texto %>'
  });
</script>
<% } %>