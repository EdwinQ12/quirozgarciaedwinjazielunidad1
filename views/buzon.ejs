<%- include('partials/header', { titulo: titulo }) %>

<%- include('partials/navbar') %>

<div class="container mt-5">

    <div class="card shadow-sm p-4">

        <h1 class="text-primary mb-4">
            Buzón de Sugerencias
        </h1>

        <form action="/buzon" method="POST">

            <div class="mb-3">

                <label class="form-label">
                    Nombre
                </label>

                <input
                    type="text"
                    name="nombre"
                    class="form-control"
                    value="<%= nombre %>"
                    readonly>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Asunto
                </label>

                <input
                    type="text"
                    name="asunto"
                    class="form-control"
                    required>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Mensaje
                </label>

                <textarea
                    name="mensaje"
                    rows="5"
                    class="form-control"
                    required></textarea>

            </div>

            <button
                type="submit"
                class="btn btn-primary">

                Enviar Mensaje

            </button>

        </form>

    </div>

</div>

<%- include('partials/footer') %>