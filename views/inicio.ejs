<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Proyecto Login</title>

    <!-- Bootstrap cdn -->
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >
</head>

<body class="bg-light">

    <div class="container mt-5">

        <div class="text-center mb-5">
            <h1>Sistema de Autenticacion</h1>

            <p class="mt-3">
                Comparacion entre un sistema de login inseguro
                usando SHA256 y un sistema seguro utilizando
                bcrypt con salt automatico.
            </p>
        </div>

        <div class="row">

            <!-- sistema inseguro -->
            <div class="col-md-6 mb-4">

                <div class="card p-4 shadow-sm">

                    <h3 class="text-danger">
                        Login Inseguro
                    </h3>

                    <p>
                        Sistema utilizando hash SHA256 sin salt.
                    </p>

                    <a href="/registro-inseguro"
                       class="btn btn-danger mb-2">
                        Registro Inseguro
                    </a>

                    <a href="/login-inseguro"
                       class="btn btn-outline-danger">
                        Login Inseguro
                    </a>

                </div>

            </div>

            <!-- sistema seguro -->
            <div class="col-md-6 mb-4">

                <div class="card p-4 shadow-sm">

                    <h3 class="text-success">
                        Login Seguro
                    </h3>

                    <p>
                        Sistema utilizando bcrypt y salt automatico.
                    </p>

                    <a href="/registro-seguro"
                       class="btn btn-success mb-2">
                        Registro Seguro
                    </a>

                    <a href="/login-seguro"
                       class="btn btn-outline-success">
                        Login Seguro
                    </a>

                </div>

            </div>

        </div>

    </div>

</body>
</html>